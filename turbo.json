{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".contentlayer/**"
      ]
    },
    "build:content": {
      "outputs": [
        ".contentlayer/**"
      ]
    },
    "check-translations": {
      "outputs": []
    },
    "clean": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "fixall": {
      "cache": false
    },
    "format": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:coverage": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:ui": {
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": [
        "^type-check",
        "build:content"
      ],
      "outputs": []
    }
  }
}
