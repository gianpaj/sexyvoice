PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_TEST_USER_EMAIL=
PLAYWRIGHT_TEST_USER_PASSWORD=

# Optional: enable the dedicated Google OAuth round-trip Playwright project.
# This uses a local Supabase custom provider plus `emulate`.
NEXT_PUBLIC_SUPABASE_GOOGLE_PROVIDER=custom:google-emulator
PLAYWRIGHT_GOOGLE_EMULATOR_URL=http://127.0.0.1:4700
