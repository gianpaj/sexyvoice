{
  "name": "@sexyvoice/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run test-links && pnpm run generate-openapi-docs && next build",
    "test-links": "tsx ./src/scripts/lint.mts",
    "generate-openapi-docs": "tsx ./src/scripts/generate-docs.mts",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.160",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@radix-ui/react-presence": "^1.1.5",
    "@takumi-rs/image-response": "^1.0.4",
    "ai": "^6.0.158",
    "class-variance-authority": "^0.7.1",
    "feed": "^5.2.0",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.7.14",
    "fumadocs-mdx": "14.2.13",
    "fumadocs-openapi": "^10.6.8",
    "fumadocs-ui": "16.7.14",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-validate-link": "^1.6.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
