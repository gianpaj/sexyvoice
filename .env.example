

# Instructions to create kv database here: https://vercel.com/docs/storage/vercel-kv/quickstart and
KV_URL=XXXXXXXX
KV_REST_API_URL=XXXXXXXX
KV_REST_API_TOKEN=XXXXXXXX
KV_REST_API_READ_ONLY_TOKEN=XXXXXXXX

# Cloudflare R2 storage
R2_ACCESS_KEY_ID=your_access_key_id
R2_BUCKET_NAME=your_bucket_name
R2_SPEECH_API_BUCKET_NAME=your_speech_api_bucket_name
R2_SPEECH_API_PUBLIC_URL=https://your-speech-api-domain.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_SECRET_ACCESS_KEY=your_secret_access_key

EDGE_CONFIG="https://edge-config.vercel.com/xxx?token=yyy"

STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# pricing table
STRIPE_PRICING_ID=prctbl_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Top-up - Test
STRIPE_TOPUP_5_PRICE_ID=price_xxxxx
STRIPE_TOPUP_10_PRICE_ID=price_xxxxx
STRIPE_TOPUP_99_PRICE_ID=price_xxxxx

# Subscription prices - Test
STRIPE_SUBSCRIPTION_5_PRICE_ID=price_xxxxx
STRIPE_SUBSCRIPTION_10_PRICE_ID=price_xxxxx
STRIPE_SUBSCRIPTION_99_PRICE_ID=price_xxxxx

NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
NEXT_PUBLIC_SUPABASE_URL=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

NEXT_PUBLIC_CRISP_WEBSITE_ID=xxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx

FAL_KEY=xxx
GOOGLE_GENERATIVE_AI_API_KEY=xxx
GOOGLE_GENERATIVE_AI_API_KEY_SECONDARY=xxx
REPLICATE_API_TOKEN=xxx
MISTRAL_API_KEY=xxx

# LiveKit real-time calls
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# External API (v1)
# API keys are created by users from Dashboard > Profile > API Keys and stored
# hashed in the `api_keys` table (no static env key required).

# Optional prompt style
NEXT_PUBLIC_STYLE_PROMPT_VARIANT_MOAN=xxx

NEXT_PUBLIC_SITE_URL=http://localhost:3000
TELEGRAM_WEBHOOK_URL=https://api.telegram.org/botxxx:yyy/sendMessage

# Generic Promotion System
# Promo campaign behavior: promo banners, bonus-credit pricing, and promo metadata
# Does not control announcement banners
NEXT_PUBLIC_PROMO_ENABLED=false
# Active promo banner id from messages.promos.* and lib/banners/registry.ts
# Only used when NEXT_PUBLIC_PROMO_ENABLED=true
NEXT_PUBLIC_ACTIVE_PROMO_BANNER=blackFridayBanner
# Active announcement banner id from messages.announcements.* and lib/banners/registry.ts
# Works independently of NEXT_PUBLIC_PROMO_ENABLED
NEXT_PUBLIC_ACTIVE_ANNOUNCEMENT_BANNER=
# NEXT_PUBLIC_PROMO_ID=halloween_2025
NEXT_PUBLIC_PROMO_ID=black_friday_2025
NEXT_PUBLIC_PROMO_THEME="pink"
NEXT_PUBLIC_PROMO_TRANSLATIONS=blackFridayBanner

# Countdown end date (UTC ISO 8601 format)
NEXT_PUBLIC_PROMO_COUNTDOWN_END_DATE=2025-11-30T23:59:59Z

# Client-side promotion variables (for UI)
NEXT_PUBLIC_PROMO_BONUS_STARTER=2000
NEXT_PUBLIC_PROMO_BONUS_STANDARD=7500
NEXT_PUBLIC_PROMO_BONUS_PRO=105000

# Inngest
INNGEST_EVENT_KEY=your_event_key_here
INNGEST_SIGNING_KEY=your_signing_key_here

# For production
INNGEST_BASE_URL=https://your-app.com/api/inngest

# Axiom logging
AXIOM_TOKEN=your_axiom_token_here

# Email notifications (Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@your-domain.com

# API key hashing — HMAC-SHA256 secret (openssl rand -hex 32)
API_KEY_HMAC_SECRET=your_hmac_secret_here

# CLI login exchange encryption secret used to encrypt one-time API key payloads
# for browser-to-CLI handoff (openssl rand -hex 32)
CLI_LOGIN_ENCRYPTION_SECRET=your_cli_login_encryption_secret_here

# OAuth callback marker signing secret (preferred over reusing API_KEY_HMAC_SECRET)
OAUTH_CALLBACK_MARKER_SECRET=your_oauth_callback_marker_secret_here
