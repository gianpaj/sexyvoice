{
  "name": "sexyvoice",
  "version": "2026.4.7",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "turbo": "2.9.14",
    "ultracite": "7.5.6"
  },
  "engines": {
    "node": "24.x"
  },
  "lint-staged": {
    "*.{js,cjs,ts,tsx,json,jsonc,css,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "packageManager": "pnpm@10.20.0",
  "private": true,
  "scripts": {
    "analyze-free-users": "pnpm --filter @sexyvoice/scripts analyze-free-users",
    "backfill-free-call": "pnpm --filter @sexyvoice/scripts backfill-free-call",
    "build": "turbo run build",
    "build:content": "turbo run build:content --filter=@sexyvoice/web",
    "check-translations": "turbo run check-translations --filter=@sexyvoice/web",
    "clean": "turbo run clean",
    "dev": "turbo run dev --filter=@sexyvoice/web",
    "fixall": "turbo run fixall",
    "format": "turbo run format",
    "generate-supabase-types": "pnpm --filter @sexyvoice/web generate-supabase-types",
    "generate-supabase-types:local": "pnpm --filter @sexyvoice/web generate-supabase-types:local",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "refund-credits": "pnpm --filter @sexyvoice/scripts refund-credits",
    "reset-freeloader-credits": "pnpm --filter @sexyvoice/scripts reset-freeloader-credits",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=@sexyvoice/web",
    "test:ui": "turbo run test:ui --filter=@sexyvoice/web",
    "type-check": "turbo run type-check"
  }
}
